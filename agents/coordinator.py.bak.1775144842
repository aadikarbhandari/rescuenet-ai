import requests
import json
import time
import logging
from typing import List, Dict, Any, Optional
from datetime import datetime

try:
    from config.settings import Settings
    from state.fleet_state import FleetState, VictimState, MissionAssignment
except ImportError:
    from typing import Any as Settings, Any as FleetState, Any as VictimState, Any as MissionAssignment


logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)


class CoordinatorAgent:
    """
    Supervisor agent for RescueNet AI - oversees full dispatch and mission planning.
    Uses DeepSeek LLM for intelligent dispatch decisions with rule-based fallback.
    """
    
    SEVERITY_ORDER = {"critical": 4, "severe": 3, "moderate": 2, "minor": 1}
    MAX_DECISIONS_HISTORY = 50
    
    def __init__(self, settings: Settings, fleet_state: FleetState):
        self.settings = settings
        self.fleet = fleet_state
        self.logger = logging.getLogger(__name__)
        self.decision_history: List[Dict[str, Any]] = []
        self.assigned_drones = set()
        
    def _call_deepseek(self, prompt: str, max_tokens: int = 2000) -> Optional[str]:
        """
        Call DeepSeek LLM API with the given prompt.
        Returns the response text or None if it fails.
        """
        if not self.settings.deepseek_api_key:
            self.logger.warning("DeepSeek API key not configured")
            return None
            
        headers = {
            "Authorization": f"Bearer {self.settings.deepseek_api_key}",
            "Content-Type": "application/json"
        }
        
        payload = {
            "model": self.settings.deepseek_model,
            "messages": [
                {"role": "system", "content": "You are a rescue coordination AI for drone disaster response. Analyze the situation and respond ONLY with valid JSON. No explanations, no markdown, just JSON."},
                {"role": "user", "content": prompt}
            ],
            "temperature": 0.3,
            "max_tokens": max_tokens
        }
        
        try:
            url = f"{self.settings.deepseek_base_url}/chat/completions"
            self.logger.info(f"Calling DeepSeek at {url}")
            
            response = requests.post(
                url,
                headers=headers,
                json=payload,
                timeout=30
            )
            response.raise_for_status()
            
            result = response.json()
            if result.get("choices") and len(result["choices"]) > 0:
                return result["choices"][0]["message"]["content"]
            else:
                self.logger.error(f"Unexpected DeepSeek response format: {result}")
                return None
                
        except requests.exceptions.Timeout:
            self.logger.error("DeepSeek API request timed out")
            return None
        except requests.exceptions.RequestException as e:
            self.logger.error(f"DeepSeek API request failed: {e}")
            return None
        except json.JSONDecodeError as e:
            self.logger.error(f"Failed to parse DeepSeek response: {e}")
            return None
        except Exception as e:
            self.logger.error(f"Unexpected error calling DeepSeek: {e}")
            return None
    
    def _build_dispatch_prompt(self, triage_results: List[VictimState], env_state: dict) -> str:
        """Build a detailed prompt for the DeepSeek LLM with current state information."""
        
        # Format drone information
        drones_info = []
        for drone_id, drone in self.fleet.drones.items():
            drones_info.append({
                "drone_id": drone_id,
                "position": list(drone.position) if hasattr(drone, 'position') else [0, 0, 0],
                "battery_percent": getattr(drone, 'battery_percent', 0),
                "status": "busy" if drone.current_mission is not None else "available",
                "winch_available": getattr(drone, 'winch_status', 'unknown') == 'operational',
                "payload_capacity_kg": getattr(drone, 'payload_kg', 0),
                "sensor_operational": getattr(drone, 'sensor_status', {}) is not None,
                "mechanical_health": getattr(drone, 'mechanical_health', 'unknown'),
                "wind_speed_ms": getattr(drone, 'wind_speed_ms', 0),
                "visibility_m": getattr(drone, 'visibility_m', 1000)
            })
        
        # Format victim information from triage results
        victims_info = []
        for victim in triage_results:
            victims_info.append({
                "victim_id": victim.victim_id if hasattr(victim, 'victim_id') else "unknown",
                "position": list(victim.position) if hasattr(victim, 'position') else [0, 0, 0],
                "severity": getattr(victim, 'injury_severity', 'moderate'),
                "needs_extraction": getattr(victim, 'needs_extraction', False),
                "needs_supplies": getattr(victim, 'needs_supplies', False),
                "needs_medical": getattr(victim, 'needs_medical', False),
                "is_confirmed": getattr(victim, 'is_confirmed', False),
                "assigned_drone": getattr(victim, 'assigned_drone', None)
            })
        
        # Get charge station positions
        charge_stations = env_state.get('charge_stations', [])
        
        # Format environmental hazards if present
        hazards = env_state.get('hazards', [])
        
        prompt = f"""You are the dispatch coordinator for RescueNet AI disaster response system.

CURRENT FLEET STATE:
{json.dumps(drones_info, indent=2)}

CHARGE STATIONS:
{json.dumps(charge_stations, indent=2)}

TRIAGE RESULTS (Victims needing rescue):
{json.dumps(victims_info, indent=2)}

ENVIRONMENTAL HAZARDS:
{json.dumps(hazards, indent=2)}

MISSION REQUIREMENTS:
- CRITICAL victims need immediate extraction if possible
- SEVERE victims need priority medical/supply delivery
- Extraction missions require drones with operational winches
- Supply missions require drones with sufficient payload capacity
- Scan/recon missions need operational sensors
- Consider battery levels - low battery drones should return to charge
- Avoid assigning busy drones
- Factor in wind speed and visibility for flight safety

Analyze the situation and decide which drones should be assigned to which victims.
Also identify any drones with critically low battery that should return to charge.

Return ONLY a valid JSON object with this exact structure (no markdown, no explanations):
{{
    "assignments": [
        {{
            "drone_id": "string",
            "victim_id": "string", 
            "mission_type": "extraction|supply|medical|scan|assist",
            "reason": "brief explanation of why this assignment makes sense"
        }}
    ],
    "drones_to_charge": ["drone_id1", "drone_id2"],
    "reasoning": "overall strategy sentence describing the dispatch decisions"
}}

Rules:
- Only assign available drones (status: 'available')
- Do not assign the same drone to multiple victims in one cycle
- Prioritize critical > severe > moderate > minor
- Assign extraction missions only to drones with operational winches
- Assign supply missions only to drones with sufficient payload
- Send drones with <20% battery to charge unless they have critical victim
- Return empty assignments array if no viable assignments possible
"""
        return prompt
    
    def _parse_dispatch_response(self, response: str) -> Optional[Dict[str, Any]]:
        """Parse the DeepSeek response into a dispatch decision."""
        try:
            # Find JSON object in response
            start = response.find('{')
            end = response.rfind('}')
            
            if start == -1 or end == -1:
                self.logger.error("No JSON object found in LLM response")
                return None
                
            json_str = response[start:end + 1]
            decision = json.loads(json_str)
            
            # Validate required fields
            if 'assignments' not in decision:
                self.logger.error("Missing 'assignments' field in LLM response")
                return None
                
            if not isinstance(decision['assignments'], list):
                self.logger.error("'assignments' must be a list")
                return None
                
            # Set defaults for missing optional fields
            decision.setdefault('drones_to_charge', [])
            decision.setdefault('reasoning', 'No reasoning provided')
            
            # Validate each assignment
            valid_assignments = []
            for assignment in decision['assignments']:
                if all(k in assignment for k in ['drone_id', 'victim_id', 'mission_type', 'reason']):
                    valid_assignments.append(assignment)
                    
            decision['assignments'] = valid_assignments
            return decision
            
        except json.JSONDecodeError as e:
            self.logger.error(f"Failed to parse dispatch JSON: {e}")
            return None
        except Exception as e:
            self.logger.error(f"Unexpected error parsing dispatch response: {e}")
            return None
    
    def _rule_based_dispatch(self, triage_results: List[VictimState], env_state: dict) -> Dict[str, Any]:
        """
        Fallback rule-based dispatch when LLM is unavailable or fails.
        Uses heuristics: severity, distance, battery, capabilities.
        """
        self.logger.info("Using rule-based dispatch fallback")
        
        assignments = []
        drones_to_charge = []
        
        # Get available drones
        available_drones = {
            drone_id: drone 
            for drone_id, drone in self.fleet.drones.items()
            if drone.current_mission is None
        }
        
        # Sort victims by severity then distance
        sorted_victims = self._prioritize_victims(triage_results, available_drones)
        
        # Track assigned drones
        assigned = set()
        
        for victim in sorted_victims:
            if not hasattr(victim, 'victim_id'):
                continue
                
            victim_id = victim.victim_id
            
            # Find best drone for this victim
            best_drone_id = self._find_best_drone(victim, available_drones, assigned)
            
            if best_drone_id is None:
                continue
                
            # Determine mission type
            mission_type = self._determine_mission_type(victim)
            
            # Check if drone has required capabilities
            drone = available_drones[best_drone_id]
            if not self._drone_can_perform_mission(drone, mission_type):
                continue
                
            # Check battery level
            battery = getattr(drone, 'battery_percent', 100)
            if battery < 20 and getattr(victim, 'injury_severity', 'moderate') != 'critical':
                drones_to_charge.append(best_drone_id)
                continue
            
            assignments.append({
                "drone_id": best_drone_id,
                "victim_id": victim_id,
                "mission_type": mission_type,
                "reason": f"Priority {self.SEVERITY_ORDER.get(getattr(victim, 'injury_severity', 'moderate'), 2)} victim assigned to nearest capable drone"
            })
            
            assigned.add(best_drone_id)
        
        # Identify low battery drones to charge
        for drone_id, drone in self.fleet.drones.items():
            if drone_id in assigned:
                continue
            battery = getattr(drone, 'battery_percent', 100)
            if battery < 20 and drone.current_mission is None:
                drones_to_charge.append(drone_id)
        
        return {
            "assignments": assignments,
            "drones_to_charge": drones_to_charge,
            "reasoning": f"Rule-based dispatch: assigned {len(assignments)} drones, {len(drones_to_charge)} to charge"
        }
    
    def _prioritize_victims(self, victims: List[VictimState], available_drones: Dict) -> List[VictimState]:
        """Sort victims by severity (descending) then distance to nearest drone (ascending)."""
        
        def victim_score(victim: VictimState) -> tuple:
            severity = getattr(victim, 'injury_severity', 'moderate')
            base = self.SEVERITY_ORDER.get(severity, 0)
            
            # Compute distance to nearest available drone
            min_dist = float('inf')
            for drone_id, drone in available_drones.items():
                if hasattr(drone, 'position'):
                    dx = drone.position[0] - victim.position[0]
                    dy = drone.position[1] - victim.position[1]
                    dist = (dx * dx + dy * dy) ** 0.5
                    min_dist = min(min_dist, dist)
            
            # Higher severity first (-base), then closer drones (min_dist)
            return (-base, min_dist)
        
        # Filter out already assigned victims
        unassigned = []
        for v in victims:
            if getattr(v, 'assigned_drone', None) is None and getattr(v, 'mission_id', None) is None:
                unassigned.append(v)
            else:
                self.logger.debug(f"Victim {getattr(v, 'victim_id', 'unknown')} already assigned - skipping")
        
        return sorted(unassigned, key=victim_score)
    
    def _find_best_drone(self, victim: VictimState, available_drones: Dict, assigned: set) -> Optional[str]:
        """Find the best available drone for a victim based on distance and capabilities."""
        best_drone = None
        best_score = (float('inf'), float('inf'))  # (distance, battery)
        
        for drone_id, drone in available_drones.items():
            if drone_id in assigned:
                continue
                
            # Calculate distance
            if hasattr(drone, 'position') and hasattr(victim, 'position'):
                dx = drone.position[0] - victim.position[0]
                dy = drone.position[1] - victim.position[1]
                distance = (dx * dx + dy * dy) ** 0.5
            else:
                distance = float('inf')
            
            # Get battery level
            battery = getattr(drone, 'battery_percent', 0)
            
            # Score: prefer closer drones with more battery
            # Lower is better
            score = (distance, -battery)
            
            if score < best_score:
                best_score = score
                best_drone = drone_id
        
        return best_drone
    
    def _determine_mission_type(self, victim: VictimState) -> str:
        """Determine the mission type based on victim needs."""
        if getattr(victim, 'needs_extraction', False):
            return "extraction"
        elif getattr(victim, 'needs_supplies', False):
            return "supply"
        elif getattr(victim, 'needs_medical', False):
            return "medical"
        else:
            return "scan"
    
    def _drone_can_perform_mission(self, drone, mission_type: str) -> bool:
        """Check if drone has required capabilities for the mission."""
        if mission_type == "extraction":
            winch = getattr(drone, 'winch_status', 'unknown')
            return winch == 'operational'
        elif mission_type in ["supply", "medical"]:
            payload = getattr(drone, 'payload_kg', 0)
            return payload >= 5  # Minimum payload for supplies
        elif mission_type == "scan":
            sensors = getattr(drone, 'sensor_status', None)
            return sensors is not None
        return True
    
    def decide_dispatch(self, triage_results: List[VictimState], env_state: dict) -> Dict[str, Any]:
        """
        Use DeepSeek to decide drone assignments for victims.
        Returns dict with assignments, drones_to_charge, and reasoning.
        Falls back to rule-based dispatch if LLM fails.
        
        Args:
            triage_results: List of victims from triage system
            env_state: Dictionary with environment info (hazards, charge stations, etc.)
            
        Returns:
            Dict with keys: assignments, drones_to_charge, reasoning
        """
        self.logger.info(f"Deciding dispatch for {len(triage_results)} victims")
        
        # Try LLM-based dispatch first
        decision = None
        used_llm = False
        
        if hasattr(self.settings, "deepseek_api_key") and hasattr(self.settings, "deepseek_base_url") and self.settings.deepseek_api_key and self.settings.deepseek_base_url:
            print(f"DEBUG: Prompt (first 500 chars): {prompt[:500]}")
            prompt = self._build_dispatch_prompt(triage_results, env_state)
            response = self._call_deepseek(prompt)
            print(f"DEBUG: Raw response: {response}")
            print(f"DEBUG: Raw DeepSeek response: {response}")
            
            if response:
                decision = self._parse_dispatch_response(response)
                if decision:
                    self.logger.info(f"LLM dispatch returned {len(decision.get('assignments', []))} assignments")
                    used_llm = True
        
        # Fall back to rule-based if LLM failed
        if decision is None:
            decision = self._rule_based_dispatch(triage_results, env_state)
        
        # Store in history
        decision_record = {
            "timestamp": datetime.now().isoformat(),
            "num_victims": len(triage_results),
            "num_assignments": len(decision.get('assignments', [])),
            "assignments": decision.get('assignments', []),
            "drones_to_charge": decision.get('drones_to_charge', []),
            "reasoning": decision.get('reasoning', ''),
            "used_llm": used_llm
        }
        
        self.decision_history.append(decision_record)
        
        # Trim history if too long
        if len(self.decision_history) > self.MAX_DECISIONS_HISTORY:
            self.decision_history = self.decision_history[-self.MAX_DECISIONS_HISTORY:]
        
        return decision
    
    def execute_dispatch(self, decision: Dict[str, Any], env) -> List[str]:
        """
        Execute the dispatch decisions: assign drones to victims, create missions.
        
        Args:
            decision: The dispatch decision from decide_dispatch()
            env: Environment object with methods to fly drones and create missions
            
        Returns:
            List of mission IDs created
        """
        self.logger.info(f"Executing dispatch with {len(decision.get('assignments', []))} assignments")
        
        mission_ids = []
        
        # Execute assignments
        for assignment in decision.get('assignments', []):
            drone_id = assignment.get('drone_id')
            victim_id = assignment.get('victim_id')
            mission_type = assignment.get('mission_type', 'scan')
            reason = assignment.get('reason', '')
            
            try:
                # Get victim and drone objects
                victim = self.fleet.get_victim(victim_id)
                drone = self.fleet.drones.get(drone_id)
                
                if not victim:
                    self.logger.warning(f"Victim {victim_id} not found in fleet state")
                    continue
                    
                if not drone:
                    self.logger.warning(f"Drone {drone_id} not found in fleet state")
                    continue
                
                # Check if drone is still available
                if drone.current_mission is not None:
                    self.logger.warning(f"Drone {drone_id} already has a mission, skipping")
                    continue
                
                # Create mission in fleet state
                mission_id = self.fleet.create_mission(
                    drone_id=drone_id,
                    victim_id=victim_id,
                    mission_type=mission_type
                )
                
                if mission_id:
                    mission_ids.append(mission_id)
                    
                    # Update victim state
                    victim.assigned_drone = drone_id
                    victim.mission_id = mission_id
                    
                    # Execute flight to victim via environment
                    if hasattr(env, 'fly_drone_to'):
                        env.fly_drone_to(drone_id, victim.position)
                        
                    # Execute mission-specific actions
                    if mission_type == 'extraction' and hasattr(env, 'perform_extraction'):
                        env.perform_extraction(drone_id, victim_id)
                    elif mission_type == 'supply' and hasattr(env, 'deliver_supplies'):
                        env.deliver_supplies(drone_id, victim_id)
                    elif mission_type == 'medical' and hasattr(env, 'deliver_medical'):
                        env.deliver_medical(drone_id, victim_id)
                    elif mission_type == 'scan' and hasattr(env, 'scan_victim'):
                        env.scan_victim(drone_id, victim_id)
                    
                    self.logger.info(f"Assigned drone {drone_id} to victim {victim_id} for {mission_type} mission: {reason}")
                else:
                    self.logger.error(f"Failed to create mission for drone {drone_id} -> victim {victim_id}")
                    
            except Exception as e:
                self.logger.error(f"Error executing dispatch for {drone_id} -> {victim_id}: {e}")
                continue
        
        # Send low-battery drones to charge
        for drone_id in decision.get('drones_to_charge', []):
            try:
                drone = self.fleet.drones.get(drone_id)
                if drone and drone.current_mission is None:
                    # Get charge station position
                    charge_stations = getattr(env, 'charge_stations', [])
                    if charge_stations:
                        nearest_station = charge_stations[0]
                        for station in charge_stations:
                            if hasattr(drone, 'position'):
                                # Find nearest
                                import math
                                dist_old = math.hypot(drone.position[0] - nearest_station[0], 
                                                      drone.position[1] - nearest_station[1])
                                dist_new = math.hypot(drone.position[0] - station[0], 
                                                      drone.position[1] - station[1])
                                if dist_new < dist_old:
                                    nearest_station = station
                        
                        if hasattr(env, 'fly_drone_to'):
                            env.fly_drone_to(drone_id, list(nearest_station))
                            
                        if hasattr(env, 'start_charging'):
                            env.start_charging(drone_id)
                            
                        self.logger.info(f"Sent drone {drone_id} to charge station")
                        
            except Exception as e:
                self.logger.error(f"Error sending drone {drone_id} to charge: {e}")
                continue
        
        return mission_ids
    
    def replan_if_needed(self, env_state: dict) -> bool:
        """
        Check if replanning is needed due to:
        - Aborted missions
        - Faulted drones
        - New critical victims
        
        Returns True if replan should be triggered.
        """
        self.logger.debug("Checking if replan is needed")
        
        # Check for aborted missions
        for mission_id, mission in self.fleet.missions.items():
            if getattr(mission, 'status', None) == 'aborted':
                self.logger.warning(f"Aborted mission detected: {mission_id}")
                return True
        
        # Check for faulted drones
        for drone_id, drone in self.fleet.drones.items():
            health = getattr(drone, 'mechanical_health', 'healthy')
            if health in ['faulted', 'critical', 'failed']:
                self.logger.warning(f"Faulted drone detected: {drone_id} (health: {health})")
                return True
                
            # Check for crashed drones
            if getattr(drone, 'status', 'active') == 'crashed':
                self.logger.warning(f"Crashed drone detected: {drone_id}")
                return True
        
        # Check for new critical victims
        for victim in self.fleet.victims.values():
            severity = getattr(victim, 'injury_severity', 'moderate')
            if severity == 'critical':
                # Check if already assigned
                if getattr(victim, 'assigned_drone', None) is None:
                    self.logger.warning(f"Unassigned critical victim detected: {victim.victim_id}")
                    return True
        
        # Check for drones stuck in transit too long
        for drone_id, drone in self.fleet.drones.items():
            if hasattr(drone, 'mission_start_time') and drone.current_mission:
                elapsed = time.time() - drone.mission_start_time
                timeout = 300  # 5 minutes default
                if elapsed > timeout:
                    self.logger.warning(f"Drone {drone_id} stuck in mission for {elapsed}s")
                    return True
        
        # Check environmental hazards that might affect safety
        hazards = env_state.get('hazards', [])
        for hazard in hazards:
            severity = hazard.get('severity', 'low')
            if severity == 'extreme':
                self.logger.warning(f"Extreme hazard detected: {hazard.get('type', 'unknown')}")
                return True
        
        return False
    
    def get_recent_decisions(self, n: int = 10) -> List[Dict[str, Any]]:
        """
        Return the last n decisions from the decision history.
        
        Args:
            n: Number of recent decisions to return (default 10)
            
        Returns:
            List of decision records
        """
        return self.decision_history[-n:] if self.decision_history else []
    
    def get_statistics(self) -> Dict[str, Any]:
        """Get coordinator statistics for dashboard."""
        total_missions = len(self.fleet.missions)
        active_missions = sum(1 for m in self.fleet.missions.values() 
                             if getattr(m, 'status', 'pending') == 'active')
        
        return {
            "total_decisions": len(self.decision_history),
            "total_missions_created": total_missions,
            "active_missions": active_missions,
            "available_drones": sum(1 for d in self.fleet.drones.values() 
                                   if d.current_mission is None),
            "total_drones": len(self.fleet.drones),
            "unassigned_victims": sum(1 for v in self.fleet.victims.values()
                                      if getattr(v, 'assigned_drone', None) is None)
        }